# ==========================================
# Community Hero - Environment Configuration
# ==========================================

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL + PostGIS)
# Using Neon.tech free tier or local docker
DATABASE_URL="postgresql://user:password@localhost:5432/community_hero?schema=public"

# Redis (Upstash or local)
REDIS_URL="redis://localhost:6379"

# Security (JWT)
JWT_SECRET="super_secret_key_change_me_in_production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# AI (Google Gemini 1.5 Flash)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# Media Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Maps API (Nominatim is free, no key needed usually, but good to have URL configurable)
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org/reverse"
